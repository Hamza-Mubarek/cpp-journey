#include <iostream>
namespace first{
int x=1;
}
namespace second{
    int x=2;
}
int main() {

    int x=4;
    std::cout<< x <<std::endl;
    std::cout<< first::x <<std::endl;
    std::cout<< second::x <<std::endl;
    //*using namespace first;* this will make the 
    //compiler to look for x in the first namespace 
    //and it will print 1 instead of 4



    return 0;
}